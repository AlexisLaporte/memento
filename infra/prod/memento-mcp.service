[Unit]
Description=Memento MCP Server
After=network.target postgresql.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/memento
EnvironmentFile=/opt/memento/.env
ExecStart=/opt/memento/venv/bin/uvicorn memento.mcp_server:app --host 127.0.0.1 --port 5003
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
